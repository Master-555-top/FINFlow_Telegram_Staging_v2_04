# FINFlow v2.45 Telegram staging environment template
# Copy to .env.local locally. Never commit .env.local.

# Public browser-safe values
NEXT_PUBLIC_SUPABASE_ANON_KEY= # optional for current server-only cloud bridge

# Server-only values
SUPABASE_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=3600
FINFLOW_DEFAULT_TIMEZONE=Asia/Kamchatka
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# Optional feature flags
FINFLOW_ENABLE_SUPABASE_WRITES=false
FINFLOW_ENABLE_CLOUD_SYNC=false
FINFLOW_ENABLE_BANK_IMPORT=false

# External AI is disabled by default
FINFLOW_ENABLE_EXTERNAL_AI=false
FINFLOW_AI_PROVIDER=
FINFLOW_N8N_WEBHOOK_URL=

# External n8n automation is fail-closed until every gate is explicitly verified.
FINFLOW_PRIVATE_N8N_WEBHOOK_URL=
FINFLOW_N8N_AUTH_READY=false
FINFLOW_N8N_REDACTION_READY=false
FINFLOW_N8N_BACKUP_READY=false
FINFLOW_ENABLE_EXTERNAL_AUTOMATION=false
