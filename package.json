{
  "name": "finflow-v3-foundation",
  "version": "0.2.49",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "node scripts/build-next.mjs",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "audit:moderate": "npm audit --audit-level=moderate",
    "verify": "npm run test && npm run typecheck && npm run build && npm audit --audit-level=moderate",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "package:staging": "node scripts/create-telegram-staging-package.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  }
}
